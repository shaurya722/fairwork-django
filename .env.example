# Copy to .env and fill in. The project reads this file at startup.

# --- Django ---
DJANGO_DEBUG=true
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_ALLOWED_HOSTS=*

# --- Award to scrape ---
AWARD_CODE=MA000100
AWARD_URL=https://awards.fairwork.gov.au/MA000100.html
AWARD_CHUNK_CHARS=3600

# --- LLM Provider ---
# Choose one: ollama | openai | groq | gemini
LLM_PROVIDER=gemini
LLM_TIMEOUT=240  

# --- Ollama (local LLM) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:7b-instruct-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120

# --- OpenAI ---
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Groq (fast Llama/Mixtral) ---
GROQ_API_KEY=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
GROQ_CHAT_MODEL=llama-3.3-70b-versatile

# --- Google Gemini ---
GEMINI_API_KEY=AIzaSyCBMNqYObsU4upJfy-pocUyWiPWwVACV1w
